{
  "name": "semver-tag-creator-action",
  "version": "1.0.0",
  "description": "Useful in builds where you want to increment the version number of a package each time you do a build.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "test": "vitest run",
    "build": "tsc --noEmit && esbuild src/main.ts --bundle --platform=node --target=node24 --format=esm --outfile=dist/index.js --minify"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tcpl/semver-tag-creator-action.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/tcpl/semver-tag-creator-action/issues"
  },
  "homepage": "https://github.com/tcpl/semver-tag-creator-action#readme",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "esbuild": "^0.27.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  }
}
