{
    "compilerOptions": {
      "module": "nodenext",
      "moduleResolution": "nodenext",
      "target": "esnext",
      "lib": ["es2022"],
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "noUnusedLocals": true,
      "noUnusedParameters": true,
      "noImplicitAny": true,
      "removeComments": false,
      "preserveConstEnums": true,
      "outDir": "./build"
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules"]
  }
